{
  "name": "ferrite",
  "displayName": "Ferrite",
  "description": "Rust-powered AI sidecar for VS Code — supports DeepSeek, OpenAI, Anthropic, and Ollama",
  "license": "MIT",
  "repository": { "type": "git", "url": "" },
  "version": "0.1.0",
  "publisher": "ferrite",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
      "viewsContainers": {
        "activitybar": [
          {
            "id": "ferrite",
            "title": "Ferrite",
            "icon": "$(robot)"
          }
        ]
      },
      "views": {
        "ferrite": [
          {
            "type": "webview",
            "id": "ferrite.chatView",
            "name": "對話",
            "icon": "$(comment-discussion)"
          }
        ]
      },
    "commands": [
      {
        "command": "ferrite.openSettings",
        "title": "Ferrite: 設定"
      },
      {
        "command": "ferrite.newSession",
        "title": "Ferrite: 新對話"
      },
      {
        "command": "ferrite.clearSessions",
        "title": "Ferrite: 清除所有對話"
      }
    ],
    "configuration": {
      "title": "Ferrite",
      "properties": {
        "ferrite.provider": {
          "type": "string",
          "enum": [
            "deepseek",
            "openai",
            "anthropic",
            "ollama"
          ],
          "default": "deepseek",
          "description": "AI 模型供應商 (Provider)"
        },
        "ferrite.apiKey": {
          "type": "string",
          "default": "",
          "description": "API 金鑰 (DeepSeek / OpenAI / Anthropic)"
        },
        "ferrite.model": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "模型名稱 (Model name)"
        },
        "ferrite.endpoint": {
          "type": "string",
          "default": "https://api.deepseek.com/",
          "description": "API Endpoint 網址"
        },
        "ferrite.temperature": {
          "type": "number",
          "default": 0.3,
          "minimum": 0,
          "maximum": 2,
          "description": "AI 創造力溫度 (0-2)"
        },
        "ferrite.timeoutSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 1,
          "maximum": 600,
          "description": "API 請求超時（秒）"
        },
        "ferrite.reasoning": {
          "type": "boolean",
          "default": false,
          "description": "啟用思考模式：AI 會先進行分析與計畫再回答"
        },
        "ferrite.reasoningEffort": {
          "type": "string",
          "enum": ["low", "medium", "high", "xhigh"],
          "default": "high",
          "description": "思考模式深度 (Reasoning effort)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && node scripts/copy-binary.js",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "build": "npm run compile && node scripts/copy-binary.js && vsce package"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^7.0.2"
  }
}